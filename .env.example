# Пример файла окружения для docker-compose.
# Скопировать в .env и при необходимости подправить значения.

# === PostgreSQL ===
POSTGRES_DB=testchat
POSTGRES_USER=testchat
POSTGRES_PASSWORD=change_me_postgres_password

# === Backend (Node.js API + WS) ===
# Порт внутри контейнера и наружу (на хосте пробрасывается на 127.0.0.1)
API_PORT=4000
# Секрет JWT — обязательно заменить на длинную случайную строку в проде
JWT_SECRET=change_me_to_a_long_random_string
# Срок жизни JWT
JWT_EXPIRES_IN=7d
# Строка подключения к БД внутри docker-сети
DATABASE_URL=postgres://testchat:change_me_postgres_password@postgres:5432/testchat
# Разрешённый origin CORS (для локальной разработки можно оставить *)
CORS_ORIGIN=*

# === Frontend (React + Vite, build-time) ===
# Путь к REST API относительно домена фронта; пустая строка = тот же origin
VITE_API_BASE=/api
# Путь к WebSocket относительно домена; wss:// сформируется автоматически
VITE_WS_PATH=/ws
