# Принудительный LF для всех текстовых файлов —
# проект запускается в Linux-контейнерах, CRLF ломает bash-скрипты и Dockerfile'ы.
* text=auto eol=lf

# Бинарные файлы не трогаем
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
